<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="KarmaBanking.App.Views.CreateSavingsAccountView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Open New Savings Account"
                   FontSize="28" FontWeight="Bold" Margin="0,0,0,24"/>

        <!-- Step 1: Choose Savings Type -->
        <StackPanel Grid.Row="1" Margin="0,0,0,24">
            <TextBlock Text="STEP 1 • CHOOSE SAVINGS TYPE"
                       FontSize="12" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,12"/>

            <RadioButton x:Name="FlexibleSavingsRadioButton"
                         Content="Flexible Savings" GroupName="SavingsType" Margin="0,0,0,8"
                         IsChecked="True" Checked="OnSavingsTypeChecked"/>
            <RadioButton x:Name="FixedDepositRadioButton"
                         Content="Fixed Deposit" GroupName="SavingsType" Margin="0,0,0,8"
                         Checked="OnSavingsTypeChecked"/>
            <RadioButton x:Name="GoalBasedSavingsRadioButton"
                         Content="Goal-Based Savings" GroupName="SavingsType"
                         Checked="OnSavingsTypeChecked"/>
        </StackPanel>

        <!-- Step 2: Account Details -->
        <StackPanel Grid.Row="2" Margin="0,0,0,24">
            <TextBlock Text="STEP 2 • ACCOUNT DETAILS"
                       FontSize="12" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,12"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Account Nickname -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,16">
                    <TextBlock Text="Account Nickname" Margin="0,0,0,4"/>
                    <TextBox x:Name="AccountNicknameTextBox"
                             PlaceholderText="e.g. Emergency"
                             Text="{Binding AccountNickname, Mode=TwoWay}"/>
                </StackPanel>

                <!-- Initial Deposit -->
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,16">
                    <TextBlock Text="Initial Deposit" Margin="0,0,0,4"/>
                    <TextBox x:Name="InitialDepositAmountTextBox"
                             PlaceholderText="1000"
                             Text="{Binding InitialDepositAmountText, Mode=TwoWay}"/>
                </StackPanel>

                <!-- Funding Source -->
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,16">
                    <TextBlock Text="Funding Source" Margin="0,0,0,4"/>
                    <ComboBox x:Name="FundingSourceComboBox"
                              PlaceholderText="Select account" HorizontalAlignment="Stretch"
                              SelectionChanged="OnFundingSourceSelected">
                        <ComboBoxItem Content="Account #1" Tag="1"/>
                        <ComboBoxItem Content="Account #2" Tag="2"/>
                    </ComboBox>
                </StackPanel>

                <!-- Deposit Frequency -->
                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,16">
                    <TextBlock Text="Deposit Frequency" Margin="0,0,0,4"/>
                    <ComboBox x:Name="DepositFrequencyComboBox" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="One Time"/>
                        <ComboBoxItem Content="Weekly"/>
                        <ComboBoxItem Content="Monthly"/>
                        <ComboBoxItem Content="Yearly"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Error Message -->
        <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" Foreground="Red"
                   Margin="0,0,0,12" Visibility="{Binding ErrorMessageVisibility}"/>

        <!-- Success Message -->
        <TextBlock Grid.Row="4" Text="Savings account opened successfully! Redirecting..."
                   Foreground="Green" FontWeight="Bold"
                   Margin="0,0,0,12" Visibility="{Binding SuccessMessageVisibility}"/>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="16">
            <Button x:Name="OpenAccountButton" Content="Open Account →"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="OnOpenAccountClicked"/>
            <Button x:Name="CancelAccountCreationButton" Content="Cancel"
                    Click="OnCancelClicked"/>
        </StackPanel>

    </Grid>
    </ScrollViewer>
</Page>
