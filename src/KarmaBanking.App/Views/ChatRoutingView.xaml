<Page
    x:Class="KarmaBanking.App.Views.ChatRoutingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Padding="24" Spacing="16">

        <TextBlock Text="Chat Completed"
                   FontSize="28"
                   FontWeight="Bold"/>

        <TextBlock x:Name="CategoryTextBlock"
                   FontSize="18"/>

        <TextBlock Text="Please rate your experience:"
                   FontSize="16"
                   Margin="0,10,0,0"/>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="⭐1" Click="Rating_Click" Tag="1"/>
            <Button Content="⭐2" Click="Rating_Click" Tag="2"/>
            <Button Content="⭐3" Click="Rating_Click" Tag="3"/>
            <Button Content="⭐4" Click="Rating_Click" Tag="4"/>
            <Button Content="⭐5" Click="Rating_Click" Tag="5"/>
        </StackPanel>

        <TextBlock x:Name="SelectedRatingText"
                   Text="No rating selected."
                   Margin="0,10,0,0"/>

        <TextBlock Text="Leave feedback (optional):"
           Margin="0,10,0,0"/>

        <TextBox x:Name="FeedbackTextBox"
         PlaceholderText="Write your feedback here..."
         AcceptsReturn="True"
         Height="80"
         TextWrapping="Wrap"/>

        <Button Content="Submit Rating"
                Click="SubmitRating_Click"
                Width="160"/>

        <TextBlock x:Name="StatusText"
                   TextWrapping="Wrap"
                   Foreground="Green"/>
        

        <Button Content="Back"
                Click="BackButton_Click"
                Width="120"
                Margin="0,20,0,0"/>

    </StackPanel>
</Page>