<Page
    x:Class="KarmaBanking.App.Views.CloseAccountDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<StackPanel Spacing="12" Padding="20">

		<!-- Title -->
		<TextBlock Text="Close Account"
                   FontSize="20"
                   FontWeight="Bold"/>

		<!-- Penalty Warning (ONLY when needed) -->
		<Border Background="#FFF3CD"
                Padding="10"
                CornerRadius="6"
                Visibility="{Binding HasPenalty}">
			<TextBlock Text="⚠ Early closure penalty applies!"
                       Foreground="OrangeRed"
                       FontWeight="Bold"
                       TextWrapping="Wrap"/>
		</Border>

		

		<!-- Destination -->
		<TextBlock Text="Select destination account:"/>

		<ComboBox ItemsSource="{Binding DestinationAccounts}"
                  SelectedValuePath="Id"
                  DisplayMemberPath="AccountName"
                  SelectedValue="{Binding SelectedDestinationAccountId, Mode=TwoWay}"/>

		<!-- Confirmation -->
		<CheckBox Content="I confirm that I want to close this account"
                  IsChecked="{Binding UserConfirmed, Mode=TwoWay}"/>

		<!-- Buttons -->
		<StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="10">

			<Button Content="Cancel"
                    Click="Cancel_Click"/>

			<Button Content="Close Account"
                    Click="Confirm_Click"
                    IsEnabled="{Binding UserConfirmed}"/>
		</StackPanel>

	</StackPanel>
</Page>