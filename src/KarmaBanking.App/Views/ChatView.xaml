<Page
    x:Class="KarmaBanking.App.Views.ChatView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Padding="24" Spacing="12">
        <TextBlock Text="Customer Support" FontSize="28" FontWeight="Bold"/>
        <TextBlock Text="How can we help you today?" FontSize="20"/>

        <ComboBox x:Name="CategoryComboBox"
                  Header="Issue Category"
                  SelectionChanged="CategoryComboBox_SelectionChanged"
                  PlaceholderText="Choose a category">
            <x:String>Account</x:String>
            <x:String>Cards</x:String>
            <x:String>Transfers</x:String>
            <x:String>Loans</x:String>
            <x:String>Technical Issue</x:String>
            <x:String>Other</x:String>
        </ComboBox>

        <Button Content="Continue"
                Command="{Binding ContinueCommand}"
                IsEnabled="{Binding CanContinue}"
                Width="140"/>

        <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"/>
    </StackPanel>
</Page>