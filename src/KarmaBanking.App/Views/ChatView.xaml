<Page
    x:Class="KarmaBanking.App.Views.ChatView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="using:KarmaBanking.App.Utils"
    mc:Ignorable="d">

    <Page.Resources>
        <utils:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="12">
            <TextBlock Text="Customer Support"
                       FontSize="28"
                       FontWeight="Bold"/>

            <TextBlock Text="How can we help you today?"
                       FontSize="20"/>

            <ListView ItemsSource="{Binding Messages}" Height="200">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4">
                            <TextBlock Text="{Binding SenderType}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding SentAt}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <ComboBox x:Name="CategoryComboBox"
                      Header="Issue Category"
                      SelectionChanged="CategoryComboBox_SelectionChanged"
                      PlaceholderText="Choose a category">
                <x:String>Account</x:String>
                <x:String>Cards</x:String>
                <x:String>Transfers</x:String>
                <x:String>Loans</x:String>
                <x:String>Technical Issue</x:String>
                <x:String>Other</x:String>
            </ComboBox>

            <Button Content="Attach File"
                    Click="AttachFileButton_Click"
                    Width="140"
                    IsEnabled="{Binding CanAttachFile}"/>

            <TextBlock Text="{Binding UploadStatusMessage}"
                       TextWrapping="Wrap"
                       Foreground="DarkBlue"/>

            <Border Padding="12"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="{Binding HasAttachmentPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Attachment Preview"
                               FontSize="18"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="{Binding SelectedAttachment.FileName}" />
                    <TextBlock Text="{Binding SelectedAttachment.FileType}" />
                    <TextBlock Text="{Binding SelectedAttachment.FileSizeDisplay}" />

                    <Button Content="Remove"
                            Command="{Binding RemoveAttachmentCommand}"
                            Width="100"/>
                </StackPanel>
            </Border>

            <Button Content="Continue"
                    Command="{Binding ContinueCommand}"
                    IsEnabled="{Binding CanContinue}"
                    Width="140"/>

            <TextBlock Text="{Binding StatusMessage}"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</Page>