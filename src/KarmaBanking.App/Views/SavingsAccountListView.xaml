<?xml version="1.0" encoding="utf-8"?>
<Page
        x:Class="KarmaBanking.App.Views.SavingsAccountListView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Savings Accounts" FontSize="28" FontWeight="Bold" Margin="0,0,0,16"/>

        <!-- Summary -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="32" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="TOTAL SAVED" FontSize="12" Foreground="Gray"/>
                <TextBlock Text="{Binding TotalSavedAmount}" FontSize="20" FontWeight="Bold"/>
                <TextBlock Text="{Binding NumberOfAccountsText}" FontSize="12" Foreground="Gray"/>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="BEST RATE" FontSize="12" Foreground="Gray"/>
                <TextBlock Text="{Binding BestInterestRate}" FontSize="20" FontWeight="Bold"/>
                <TextBlock Text="Fixed Deposit" FontSize="12" Foreground="Gray"/>
            </StackPanel>
        </StackPanel>

        <!-- Tabs -->
        <NavigationView Grid.Row="2" x:Name="MainNavigationView"
                        IsBackButtonVisible="Collapsed" PaneDisplayMode="Top"
                        Margin="0,0,0,16" SelectionChanged="OnTabSelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="MyAccountsTab" Content="My Accounts"/>
                <NavigationViewItem x:Name="OpenNewTab" Content="Open New"/>
                <NavigationViewItem Content="Manage"/>
            </NavigationView.MenuItems>
        </NavigationView>

        <!-- My Accounts Content -->
        <Grid Grid.Row="3" x:Name="MyAccountsContent">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Empty state -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding EmptyStateVisibility}">
                <TextBlock Text="No savings accounts yet." FontSize="16" Foreground="Gray" HorizontalAlignment="Center"/>
                <TextBlock Text="Go to Open New to get started." FontSize="14" Foreground="Gray" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Accounts Table -->
            <ListView x:Name="AccountsListView"
              Grid.Row="0"
              ItemsSource="{Binding SavingsAccounts}"
              Visibility="{Binding AccountsListVisibility}"
              SelectionMode="Single">
                <ListView.HeaderTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Account Name" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Text="Type" FontWeight="Bold"/>
                            <TextBlock Grid.Column="2" Text="Balance" FontWeight="Bold"/>
                            <TextBlock Grid.Column="3" Text="Interest" FontWeight="Bold"/>
                            <TextBlock Grid.Column="4" Text="Status" FontWeight="Bold"/>
                        </Grid>
                    </DataTemplate>
                </ListView.HeaderTemplate>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding AccountName}"/>
                            <TextBlock Grid.Column="1" Text="{Binding SavingsType}"/>
                            <TextBlock Grid.Column="2" Text="{Binding Balance}"/>
                            <TextBlock Grid.Column="3" Text="{Binding AccruedInterest}"/>
                            <Border Grid.Column="4" CornerRadius="8" Padding="8,4" Background="LightGray">
                                <TextBlock Text="{Binding AccountStatus}"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Action Buttons (Manage only) -->
            <StackPanel Grid.Row="1" x:Name="ManageActionButtons" Orientation="Horizontal"
                        Spacing="8" Margin="0,8,0,0" Visibility="Collapsed">
                <Button Content="Details"/>
                <Button Content="Deposit"
                Click="Deposit_Click"/>
                <Button Content="Withdraw"/>
                <Button Content="Close Account"
                Click="CloseAccount_Click"/>
            </StackPanel>
        </Grid>

        <!-- Open New Content (Frame) -->
        <Frame Grid.Row="3" x:Name="OpenNewFrame" Visibility="Collapsed"/>
    </Grid>
</Page>
