<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="KarmaBanking.App.Views.LoansView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="20">

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Loans Dashboard"
                           FontSize="28" FontWeight="Bold"/>
                <Button Grid.Column="1" Content="+ Apply for a Loan"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="OnApplyClick"/>
            </Grid>

            <ProgressRing IsActive="{Binding IsLoading}"
                          Visibility="{x:Bind _viewModel.IsLoading, Mode=OneWay}"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,10"/>


            <InfoBar IsOpen="{Binding HasError}"
                       Visibility="{x:Bind _viewModel.IsLoading, Mode=OneWay}"
                     Severity="Error"
                     Message="{Binding ErrorMessage}"
                     IsClosable="False"
                     Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,0,0,16">

              
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="All" Click="OnFilterAll"/>
                    <Button Content="Active" Click="OnFilterActive"/>
                    <Button Content="Closed" Click="OnFilterClosed"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Type:" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding LoanTypes}"
                  SelectedItem="{Binding TypeFilter, Mode=TwoWay}"
                  PlaceholderText="All types"
                  MinWidth="120"/>
                </StackPanel>

            </StackPanel>



            <ListView ItemsSource="{Binding FilteredLoans}"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Gray"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,0,0,12"
                                Padding="16">
                            <StackPanel>


                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Loan.LoanType}"
                                               FontSize="20" FontWeight="SemiBold"/>
                                    <Border Grid.Column="1" CornerRadius="12" Padding="10,4"
                                            Background="LightGray">
                                        <TextBlock Text="{Binding Loan.LoanStatus}"
                                                   FontSize="12" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>


                                <StackPanel Orientation="Horizontal" Spacing="24" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="PRINCIPAL" FontSize="11" Foreground="Gray"/>
                                        <TextBlock Text="{Binding Loan.Principal}" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="BALANCE" FontSize="11" Foreground="Gray"/>
                                        <TextBlock Text="{Binding Loan.OutstandingBalance}" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="INTEREST" FontSize="11" Foreground="Gray"/>
                                        <TextBlock FontWeight="Bold">
                                            <Run Text="{Binding Loan.InterestRate}"/>
                                            <Run Text="%"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="MONTHLY" FontSize="11" Foreground="Gray"/>
                                        <TextBlock Text="{Binding Loan.MonthlyInstallment}" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="REMAINING" FontSize="11" Foreground="Gray"/>
                                        <TextBlock FontWeight="Bold">
                                            <Run Text="{Binding Loan.RemainingMonths}"/>
                                            <Run Text=" mo"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>


                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Repayment progress"
                                               FontSize="12" Foreground="Gray"/>
                                    <TextBlock Grid.Column="1" FontSize="12" Foreground="Gray">
                                        <Run Text="{Binding RepaymentProgress}"/>
                                        <Run Text="%"/>
                                    </TextBlock>
                                </Grid>
                                <ProgressBar Value="{Binding RepaymentProgress}"
                                             Minimum="0" Maximum="100"
                                             Height="6" CornerRadius="3"
                                             Margin="0,0,0,12"/>


                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Pay Installment"
                                            Tag="{Binding}"
                                            Click="OnPayClick"/>
                                    <Button Content="Schedule"
                                            Tag="{Binding}"
                                            Click="OnScheduleClick"/>
                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>
    </ScrollViewer>
</Page>